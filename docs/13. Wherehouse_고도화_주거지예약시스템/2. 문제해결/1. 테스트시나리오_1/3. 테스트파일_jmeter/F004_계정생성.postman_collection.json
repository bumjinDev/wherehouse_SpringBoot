      "name": "2. 로그인 (11개) — Set-Cookie 의 JWT 자동 추출",
      "item": [
        {
          "name": "01. ownerTest1 로그인 → JWT_OWNER1",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const setCookie = pm.response.headers.get('Set-Cookie');",
                  "if (setCookie) {",
                  "    const m = setCookie.match(/Authorization=([^;]+)/);",
                  "    if (m) {",
                  "        pm.collectionVariables.set('JWT_OWNER1', m[1]);",
                  "        console.log('JWT_OWNER1 =', m[1]);",
                  "    } else {",
                  "        console.warn('Set-Cookie 에서 Authorization 쿠키를 못 찾음');",
                  "    }",
                  "} else {",
                  "    console.warn('Set-Cookie 헤더 없음');",
                  "}",
                  "pm.test('로그인 응답 코드 200/302', function() {",
                  "    pm.expect([200, 302]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"userid\":   \"ownerTest1\",\n  \"password\": \"Owner1234!\"\n}" },
            "url": { "raw": "{{BASE_URL}}/login", "host": ["{{BASE_URL}}"], "path": ["login"] }
